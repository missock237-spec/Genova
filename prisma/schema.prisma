generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents              Agent[]
  workflows           Workflow[]
  guardrails          Guardrail[]
  activities          ActivityLog[]
  conversations       Conversation[]
  knowledge           Knowledge[]
  documents           Document[]
  executions          AgentExecution[]
  episodicMemories    EpisodicMemory[]
  memoryAccessLogs    MemoryAccessLog[]
  embeddingVectors    EmbeddingVector[]
  executionPolicies   ExecutionPolicy[]
  websocketSessions   WebSocketSession[]
  sessions            Session[]
  passwordResets      PasswordReset[]
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  type         String
  description  String
  status       String   @default("inactive")
  config       String
  avatar       String?
  capabilities String   @default("{}") // JSON: tool capabilities and permissions per agent
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks           Task[]
  conversations   Conversation[]
  executions      AgentExecution[]
  toolPermissions ToolPermission[]

  @@map("agents")
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   @default("draft")
  steps       String
  trigger     String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("workflows")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  result      String?
  agentId     String?
  workflowId  String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  validations Validation[]

  @@map("tasks")
}

model Guardrail {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  rules       String
  severity    String   @default("warning")
  isActive    Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  validations Validation[]

  @@map("guardrails")
}

model Validation {
  id          String   @id @default(cuid())
  status      String
  result      String
  guardrailId String
  taskId      String
  createdAt   DateTime @default(now())

  guardrail   Guardrail @relation(fields: [guardrailId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("validations")
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  details     String
  category    String
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model Conversation {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("automation") // automation, agent_chat, orchestration
  status      String    @default("active") // active, archived
  agentId     String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages    Message[]
  executions  AgentExecution[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  role           String   // user, assistant, system
  content        String
  model          String?  // Which AI model was used
  provider       String?  // groq or openrouter
  tokensUsed     Int?
  conversationId String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Knowledge {
  id          String   @id @default(cuid())
  content     String
  category    String   // preference, project, document, workflow_context, agent_learning
  tags        String   // JSON array of tags
  source      String   // conversation, document, manual
  relevance   Float    @default(0.5)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("knowledge")
}

model Document {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String
  fileSize    Int
  content     String?  // Full text content
  status      String   @default("processing") // processing, ready, error
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks      DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(cuid())
  content     String
  chunkIndex  Int
  pageNumber  Int?
  metadata    String   // JSON: additional metadata
  documentId  String
  userId      String
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model AgentExecution {
  id          String   @id @default(cuid())
  agentId     String
  task        String
  steps       String   // JSON: array of execution steps
  status      String   @default("running") // running, completed, failed, paused
  totalDuration Int?
  totalTokens Int?
  estimatedCost Float?
  model       String?
  provider    String?
  userId      String
  conversationId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@map("agent_executions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Episodic Memory System
// Stores agent experiences as discrete episodes with contextual metadata,
// emotional valence, and learned lessons for future retrieval and reasoning.
// ─────────────────────────────────────────────────────────────────────────────
model EpisodicMemory {
  id              String    @id @default(cuid())
  userId          String
  agentId         String
  episode         String    // What happened
  context         String    // Context of the episode
  outcome         String    // What was the result
  emotionalValence Float    @default(0) // -1 (negative) to 1 (positive)
  learnedLesson   String    // What was learned
  tags            String    @default("[]") // JSON array
  retrievalScore  Float     @default(0.5) // How often this is retrieved
  accessCount     Int       @default(0)
  importance      Float     @default(0.5)
  createdAt       DateTime  @default(now())
  lastAccessedAt  DateTime  @default(now())
  expiresAt       DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@index([userId, createdAt])
  @@map("episodic_memories")
}

// ─────────────────────────────────────────────────────────────────────────────
// Memory Access Log
// Tracks which memories (Knowledge or EpisodicMemory) are retrieved and used,
// enabling retrieval score decay/growth, relevance feedback, and analytics.
// ─────────────────────────────────────────────────────────────────────────────
model MemoryAccessLog {
  id          String   @id @default(cuid())
  memoryId    String   // Reference to Knowledge or EpisodicMemory
  memoryType  String   // "knowledge" or "episodic"
  userId      String
  query       String   // The search query that triggered this access
  score       Float    // Relevance score at retrieval time
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@index([userId, createdAt])
  @@map("memory_access_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Embedding Vector Store
// Persists vector embeddings for RAG (Retrieval-Augmented Generation).
//
// With PostgreSQL + pgvector: native cosine / L2 similarity search.
// Requires: CREATE EXTENSION IF NOT EXISTS vector;
// ─────────────────────────────────────────────────────────────────────────────
model EmbeddingVector {
  id          String              @id @default(cuid())
  entityId    String              // ID of the entity this embedding represents (chunk, knowledge, etc.)
  entityType  String              // "document_chunk" | "knowledge" | "episodic_memory"
  vector      Unsupported("vector(384)")
  dimension   Int                 @default(384)
  userId      String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityId, entityType])
  @@index([entityType, userId])
  @@map("embedding_vectors")
}

// ─────────────────────────────────────────────────────────────────────────────
// Tool Permission System
// Granular per-agent tool permissions with scope, actions, constraints,
// and call limits for the capability-based security model.
// ─────────────────────────────────────────────────────────────────────────────
model ToolPermission {
  id          String    @id @default(cuid())
  agentId     String
  toolName    String    // Which tool this permission applies to
  actions     String    @default("[]") // JSON array: ["read", "write", "execute", "network"]
  scope       String    @default("none") // "full" | "limited" | "none"
  constraints String    @default("[]") // JSON array of constraint strings
  maxCalls    Int       @default(-1) // -1 = unlimited
  callCount   Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolName])
  @@map("tool_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Execution Policy
// Defines rules and constraints for agent execution, including retries,
// timeouts, and per-agent-type policy assignments.
// ─────────────────────────────────────────────────────────────────────────────
model ExecutionPolicy {
  id          String   @id @default(cuid())
  name        String
  description String
  rules       String   // JSON: execution policy rules
  agentTypes  String   @default("[]") // JSON: which agent types this applies to
  maxRetries  Int      @default(3)
  timeout     Int      @default(30000)
  userId      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("execution_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// WebSocket Session
// Tracks active and historical WebSocket connections per user,
// including connected agent IDs, status, and connection metadata.
// ─────────────────────────────────────────────────────────────────────────────
model WebSocketSession {
  id          String    @id @default(cuid())
  userId      String
  agentIds    String    @default("[]") // JSON: connected agent IDs
  status      String    @default("active") // active, closed, error
  metadata    String    @default("{}") // JSON: connection metadata
  createdAt   DateTime  @default(now())
  lastPingAt  DateTime  @default(now())
  closedAt    DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("websocket_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// User Session
// Stores authenticated session tokens for API authorization.
// Each session has a unique token (Bearer token), expires after a set time,
// and is scoped to a single user. This prevents unauthorized cross-user access.
// ─────────────────────────────────────────────────────────────────────────────
model Session {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Password Reset
// Stores 6-digit verification codes sent by email for password recovery.
// Codes expire after 15 minutes. Max 3 attempts to enter the code.
// ─────────────────────────────────────────────────────────────────────────────
model PasswordReset {
  id         String    @id @default(cuid())
  email      String
  code       String    // 6-digit verification code
  attempts   Int       @default(0)
  used       Boolean   @default(false)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, code])
  @@index([userId])
  @@map("password_resets")
}

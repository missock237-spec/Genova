generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  avatar         String?
  plan           String   @default("free")
  role           String   @default("user")      // user, admin, super_admin
  emailVerified  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agents           Agent[]
  workflows        Workflow[]
  guardrails       Guardrail[]
  activities       ActivityLog[]
  sessions         Session[]
  socialAccounts   SocialAccount[]
  whatsappConfig   WhatsAppConfig?
  resources        UserResource[]
  approvalRequests ApprovalRequest[]
  agentPermissions AgentPermission[]
  agentActionLogs  AgentActionLog[]
  browserSessions  BrowserSession[]
  passwordResets   PasswordReset[]
  agentUsages      AgentUsage[]
  aiCosts          AICost[]
  usageDaily       UsageDaily[]
  monitoringEvents MonitoringEvent[]
  emailVerifications EmailVerification[]
  imageGenerations  ImageGeneration[]
  memories          AgentMemory[]
  conversations     Conversation[]
  knowledgeEntries  Knowledge[]
  documents         Document[]
  documentChunks    DocumentChunk[]
  auditLogs         AuditLog[]

  @@index([role])
  @@map("users")
}

model Session {
  id               String    @id @default(cuid())
  token            String    @unique
  userId           String
  refreshToken     String?   @unique
  expiresAt        DateTime
  refreshExpiresAt DateTime?
  createdAt        DateTime  @default(now())
  lastAccessedAt   DateTime  @default(now())
  ipAddress        String?
  userAgent        String?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, code])
  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, code])
  @@map("email_verifications")
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  status      String   @default("inactive")
  config      String
  avatar      String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  permissions AgentPermission[]
  actions     AgentActionLog[]
  browserSessions BrowserSession[]
  agentUsages AgentUsage[]
  memories    AgentMemory[]

  @@map("agents")
}

model AgentPermission {
  id               String  @id @default(cuid())
  agentId          String
  permission       String
  granted          Boolean @default(false)
  requiresApproval Boolean @default(true)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agent            Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agentId, permission])
  @@map("agent_permissions")
}

model AgentActionLog {
  id        String   @id @default(cuid())
  agentId   String?
  action    String
  details   String
  status    String   @default("pending")
  result    String?
  userId    String
  createdAt DateTime @default(now())
  resolvedAt DateTime?

  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_action_logs")
}

model BrowserSession {
  id         String   @id @default(cuid())
  agentId    String
  url        String   @default("about:blank")
  title      String?
  status     String   @default("idle")
  screenshot String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("browser_sessions")
}

model SocialAccount {
  id           String   @id @default(cuid())
  platform     String
  accountId    String
  accountName  String
  accessToken  String
  refreshToken String?
  isActive     Boolean  @default(true)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, accountId])
  @@map("social_accounts")
}

model WhatsAppConfig {
  id            String   @id @default(cuid())
  phoneNumber   String
  whatsappId    String?
  phoneNumberId String?   // WhatsApp Cloud API Phone Number ID (from Meta Business settings)
  apiToken      String?
  isActive      Boolean  @default(false)
  autoMessage   Boolean  @default(false)
  autoCall      Boolean  @default(false)
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("whatsapp_configs")
}

model UserResource {
  id        String   @id @default(cuid())
  type      String
  name      String
  config    String
  apiKey    String?
  endpoint  String?
  isActive  Boolean  @default(true)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_resources")
}

model ApprovalRequest {
  id          String   @id @default(cuid())
  agentId     String
  action      String
  details     String
  status      String   @default("pending")
  result      String?
  userId      String
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

model Workflow {
  id               String   @id @default(cuid())
  name             String
  description      String
  status           String   @default("draft")
  steps            String
  trigger          String
  currentTaskIndex Int      @default(0)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks            Task[]

  @@map("workflows")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  result      String?
  agentId     String?
  workflowId  String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  validations Validation[]

  @@map("tasks")
}

model Guardrail {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  rules       String
  severity    String   @default("warning")
  isActive    Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  validations Validation[]

  @@map("guardrails")
}

model Validation {
  id          String   @id @default(cuid())
  status      String
  result      String
  guardrailId String
  taskId      String
  createdAt   DateTime @default(now())

  guardrail   Guardrail @relation(fields: [guardrailId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("validations")
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  details     String
  category    String
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model AgentUsage {
  id          String   @id @default(cuid())
  agentId     String
  userId      String
  action      String
  tokensUsed  Int      @default(0)
  duration    Int      @default(0)
  status      String   @default("success")
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@map("agent_usage")
}

model AICost {
  id              String   @id @default(cuid())
  userId          String
  agentId         String?
  provider        String
  model           String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  costUsd         Float    @default(0)
  requestId       String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@map("ai_costs")
}

model UsageDaily {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  agentCount   Int      @default(0)
  taskCount    Int      @default(0)
  totalTokens  Int      @default(0)
  totalCostUsd Float    @default(0)
  apiCalls     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("usage_daily")
}

model MonitoringEvent {
  id         String    @id @default(cuid())
  userId     String
  eventType  String
  source     String
  message    String
  details    String    @default("{}")
  severity   String    @default("info")
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, severity])
  @@map("monitoring_events")
}

// ============================================================
// Agent Memory — Per-agent learning database
// Each agent has its own knowledge base that grows with use,
// allowing it to better understand user requests over time.
// ============================================================

model AgentMemory {
  id            String   @id @default(cuid())
  agentId       String
  userId        String
  category      String   @default("general")   // general, preference, episodic, procedural, semantic
  content       String                          // The learned knowledge
  context       String   @default("{}")         // JSON: context in which this was learned
  source        String   @default("interaction") // interaction, observation, feedback, system
  relevance     Float    @default(0.5)          // 0-1, how important this memory is
  accessCount   Int      @default(0)            // How often this memory is retrieved
  tags          String   @default("[]")         // JSON array of tags for categorization
  embedding     String?                          // Vector embedding for semantic search (JSON)
  createdAt     DateTime @default(now())
  lastAccessedAt DateTime @default(now())
  expiresAt     DateTime?                        // Optional TTL for temporary memories

  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId, category])
  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@map("agent_memories")
}

// ============================================================
// URL Blocklist — Malicious site protection
// Stores known malicious URLs/domains to protect the system
// from phishing, malware, and other threats.
// ============================================================

model URLBlocklist {
  id          String   @id @default(cuid())
  domain      String   @unique                    // Domain or URL pattern
  reason      String                              // Why it's blocked
  threatType  String   @default("malware")        // malware, phishing, spam, scam, suspicious
  severity    String   @default("high")           // low, medium, high, critical
  source      String   @default("system")         // system, user, auto_detected
  isActive    Boolean  @default(true)
  hits        Int      @default(0)                // How many times this was triggered
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([isActive])
  @@map("url_blocklist")
}

// ============================================================
// Image Generation — Track AI-generated images
// ============================================================

model ImageGeneration {
  id              String   @id @default(cuid())
  userId          String
  prompt          String                          // The text prompt used
  model           String                          // Model used for generation
  provider        String   @default("openrouter") // Provider (openrouter, etc.)
  imageUrl        String?                         // URL or base64 of generated image
  status          String   @default("pending")    // pending, completed, failed
  costUsd         Float    @default(0)
  width           Int?
  height          Int?
  metadata        String   @default("{}")         // JSON metadata
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@map("image_generations")
}

// ============================================================
// Conversation — Chat conversations with agents
// ============================================================

model Conversation {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("chat")     // chat, automation, support
  userId    String
  agentId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, createdAt])
  @@map("conversations")
}

// ============================================================
// Message — Individual messages within conversations
// ============================================================

model Message {
  id             String   @id @default(cuid())
  role           String                       // user, assistant, system
  content        String
  model          String?
  provider       String?
  conversationId String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================
// Knowledge — User knowledge base for long-term memory & RAG
// ============================================================

model Knowledge {
  id        String   @id @default(cuid())
  content   String
  category  String   @default("general")   // preference, project, document, workflow_context, agent_learning, episodic, semantic
  tags      String   @default("[]")
  source    String   @default("manual")     // conversation, document, manual, episodic, summarization
  relevance Float    @default(0.5)
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, createdAt])
  @@map("knowledge")
}

// ============================================================
// Document & DocumentChunk — RAG document storage
// ============================================================

model Document {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String   @default("unknown")
  fileSize  Int      @default(0)
  content   String   @default("")
  status    String   @default("processing")  // processing, ready, failed
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    DocumentChunk[]

  @@index([userId, createdAt])
  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(cuid())
  content     String
  chunkIndex  Int      @default(0)
  pageNumber  Int?
  metadata    String   @default("{}")
  documentId  String
  userId      String
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

// ============================================================
// Agent Execution — Execution state persistence for agents
// ============================================================

model AgentExecution {
  id              String   @id @default(cuid())
  agentId         String
  userId          String
  task            String   @default("")
  steps           String   @default("[]")
  currentStep     Int      @default(0)
  totalSteps      Int      @default(0)
  status          String   @default("pending")    // pending, running, completed, failed, paused
  totalDuration   Int      @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  model           String?
  provider        String?
  result          String?
  error           String?
  state           String   @default("{}")         // JSON execution state
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@map("agent_executions")
}

// ============================================================
// Audit Log — Security audit trail for auth & admin actions
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String                          // login, logout, session_create, session_revoke, password_change, role_change, admin_action, etc.
  resource    String   @default("")           // Target resource type (user, agent, session, etc.)
  resourceId  String   @default("")           // Target resource ID
  details     String   @default("{}")         // JSON details of the action
  ipAddress   String?                         // Client IP at the time of action
  userAgent   String?                         // Client User-Agent
  severity    String   @default("info")       // info, warning, critical
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([severity, createdAt])
  @@map("audit_logs")
}

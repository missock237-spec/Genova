generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents        Agent[]
  workflows     Workflow[]
  guardrails    Guardrail[]
  activities    ActivityLog[]
  conversations Conversation[]
  knowledge     Knowledge[]
  documents     Document[]
  executions    AgentExecution[]
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  status      String   @default("inactive")
  config      String
  avatar      String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         Task[]
  conversations Conversation[]
  executions    AgentExecution[]

  @@map("agents")
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   @default("draft")
  steps       String
  trigger     String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("workflows")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  result      String?
  agentId     String?
  workflowId  String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  validations Validation[]

  @@map("tasks")
}

model Guardrail {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  rules       String
  severity    String   @default("warning")
  isActive    Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  validations Validation[]

  @@map("guardrails")
}

model Validation {
  id          String   @id @default(cuid())
  status      String
  result      String
  guardrailId String
  taskId      String
  createdAt   DateTime @default(now())

  guardrail   Guardrail @relation(fields: [guardrailId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("validations")
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  details     String
  category    String
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model Conversation {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("automation") // automation, agent_chat, orchestration
  status      String    @default("active") // active, archived
  agentId     String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages    Message[]
  executions  AgentExecution[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  role           String   // user, assistant, system
  content        String
  model          String?  // Which AI model was used
  provider       String?  // groq or openrouter
  tokensUsed     Int?
  conversationId String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Knowledge {
  id          String   @id @default(cuid())
  content     String
  category    String   // preference, project, document, workflow_context, agent_learning
  tags        String   // JSON array of tags
  source      String   // conversation, document, manual
  relevance   Float    @default(0.5)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("knowledge")
}

model Document {
  id          String   @id @default(cuid())
  fileName    String
  fileType    String
  fileSize    Int
  content     String?  // Full text content
  status      String   @default("processing") // processing, ready, error
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks      DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(cuid())
  content     String
  chunkIndex  Int
  pageNumber  Int?
  metadata    String   // JSON: additional metadata
  documentId  String
  userId      String
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model AgentExecution {
  id          String   @id @default(cuid())
  agentId     String
  task        String
  steps       String   // JSON: array of execution steps
  status      String   @default("running") // running, completed, failed, paused
  totalDuration Int?
  totalTokens Int?
  estimatedCost Float?
  model       String?
  provider    String?
  userId      String
  conversationId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@map("agent_executions")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  avatar         String?
  plan           String   @default("free")
  role           String   @default("user")      // user, admin, super_admin
  emailVerified  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agents           Agent[]
  workflows        Workflow[]
  guardrails       Guardrail[]
  activities       ActivityLog[]
  sessions         Session[]
  socialAccounts   SocialAccount[]
  whatsappConfig   WhatsAppConfig?
  resources        UserResource[]
  approvalRequests ApprovalRequest[]
  agentPermissions AgentPermission[]
  agentActionLogs  AgentActionLog[]
  browserSessions  BrowserSession[]
  passwordResets   PasswordReset[]
  agentUsages      AgentUsage[]
  aiCosts          AICost[]
  usageDaily       UsageDaily[]
  monitoringEvents MonitoringEvent[]
  emailVerifications EmailVerification[]
  imageGenerations  ImageGeneration[]
  videoGenerations  VideoGeneration[]
  memories          AgentMemory[]
  conversations     Conversation[]
  knowledgeEntries  Knowledge[]
  documents         Document[]
  documentChunks    DocumentChunk[]
  auditLogs         AuditLog[]
  voiceProfiles     VoiceProfile[]
  voiceSessions     VoiceSession[]
  voiceMemories     VoiceMemory[]
  voiceCalls        VoiceCall[]
  scheduledTasks    ScheduledTask[]
  agentAutomations  AgentAutomation[]
  workspaceMemberships WorkspaceMember[]
  marketplaceListings MarketplaceListing[]
  marketplaceReviews MarketplaceReview[]
  marketplacePurchases MarketplacePurchase[]
  browserAutomations BrowserAutomation[]
  avatarConfigs     AvatarConfig[]
  avatarSessions    AvatarSession[]
  multimodalSessions MultimodalSession[]
  memoryNodes       MemoryNode[]
  memoryEdgesFrom   MemoryEdge[]
  workspaceActivities WorkspaceActivity[]
  personalization   UserPersonalization?

  @@index([role])
  @@map("users")
}

model Session {
  id               String    @id @default(cuid())
  token            String    @unique
  userId           String
  refreshToken     String?   @unique
  expiresAt        DateTime
  refreshExpiresAt DateTime?
  createdAt        DateTime  @default(now())
  lastAccessedAt   DateTime  @default(now())
  ipAddress        String?
  userAgent        String?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, code])
  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, code])
  @@map("email_verifications")
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  status      String   @default("inactive")
  config      String
  avatar      String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  permissions AgentPermission[]
  actions     AgentActionLog[]
  browserSessions BrowserSession[]
  agentUsages AgentUsage[]
  memories    AgentMemory[]

  @@map("agents")
}

model AgentPermission {
  id               String  @id @default(cuid())
  agentId          String
  permission       String
  granted          Boolean @default(false)
  requiresApproval Boolean @default(true)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  agent            Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agentId, permission])
  @@map("agent_permissions")
}

model AgentActionLog {
  id        String   @id @default(cuid())
  agentId   String?
  action    String
  details   String
  status    String   @default("pending")
  result    String?
  userId    String
  createdAt DateTime @default(now())
  resolvedAt DateTime?

  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_action_logs")
}

model BrowserSession {
  id         String   @id @default(cuid())
  agentId    String
  url        String   @default("about:blank")
  title      String?
  status     String   @default("idle")
  screenshot String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("browser_sessions")
}

model SocialAccount {
  id           String   @id @default(cuid())
  platform     String
  accountId    String
  accountName  String
  accessToken  String
  refreshToken String?
  isActive     Boolean  @default(true)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform, accountId])
  @@map("social_accounts")
}

model WhatsAppConfig {
  id            String   @id @default(cuid())
  phoneNumber   String
  whatsappId    String?
  phoneNumberId String?   // WhatsApp Cloud API Phone Number ID (from Meta Business settings)
  apiToken      String?
  isActive      Boolean  @default(false)
  autoMessage   Boolean  @default(false)
  autoCall      Boolean  @default(false)
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("whatsapp_configs")
}

model UserResource {
  id        String   @id @default(cuid())
  type      String
  name      String
  config    String
  apiKey    String?
  endpoint  String?
  isActive  Boolean  @default(true)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_resources")
}

model ApprovalRequest {
  id          String   @id @default(cuid())
  agentId     String
  action      String
  details     String
  status      String   @default("pending")
  result      String?
  userId      String
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

model Workflow {
  id               String   @id @default(cuid())
  name             String
  description      String
  status           String   @default("draft")
  steps            String
  trigger          String
  currentTaskIndex Int      @default(0)
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks            Task[]

  @@map("workflows")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  result      String?
  agentId     String?
  workflowId  String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  validations Validation[]

  @@map("tasks")
}

model Guardrail {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  rules       String
  severity    String   @default("warning")
  isActive    Boolean  @default(true)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  validations Validation[]

  @@map("guardrails")
}

model Validation {
  id          String   @id @default(cuid())
  status      String
  result      String
  guardrailId String
  taskId      String
  createdAt   DateTime @default(now())

  guardrail   Guardrail @relation(fields: [guardrailId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("validations")
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  details     String
  category    String
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model AgentUsage {
  id          String   @id @default(cuid())
  agentId     String
  userId      String
  action      String
  tokensUsed  Int      @default(0)
  duration    Int      @default(0)
  status      String   @default("success")
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())

  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@map("agent_usage")
}

model AICost {
  id              String   @id @default(cuid())
  userId          String
  agentId         String?
  provider        String
  model           String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  costUsd         Float    @default(0)
  requestId       String?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@map("ai_costs")
}

model UsageDaily {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  agentCount   Int      @default(0)
  taskCount    Int      @default(0)
  totalTokens  Int      @default(0)
  totalCostUsd Float    @default(0)
  apiCalls     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("usage_daily")
}

model MonitoringEvent {
  id         String    @id @default(cuid())
  userId     String
  eventType  String
  source     String
  message    String
  details    String    @default("{}")
  severity   String    @default("info")
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, severity])
  @@map("monitoring_events")
}

// ============================================================
// Agent Memory — Per-agent learning database
// Each agent has its own knowledge base that grows with use,
// allowing it to better understand user requests over time.
// ============================================================

model AgentMemory {
  id            String   @id @default(cuid())
  agentId       String
  userId        String
  category      String   @default("general")   // general, preference, episodic, procedural, semantic
  content       String                          // The learned knowledge
  context       String   @default("{}")         // JSON: context in which this was learned
  source        String   @default("interaction") // interaction, observation, feedback, system
  relevance     Float    @default(0.5)          // 0-1, how important this memory is
  accessCount   Int      @default(0)            // How often this memory is retrieved
  tags          String   @default("[]")         // JSON array of tags for categorization
  embedding     String?                          // Vector embedding for semantic search (JSON)
  createdAt     DateTime @default(now())
  lastAccessedAt DateTime @default(now())
  expiresAt     DateTime?                        // Optional TTL for temporary memories

  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId, category])
  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@map("agent_memories")
}

// ============================================================
// URL Blocklist — Malicious site protection
// Stores known malicious URLs/domains to protect the system
// from phishing, malware, and other threats.
// ============================================================

model URLBlocklist {
  id          String   @id @default(cuid())
  domain      String   @unique                    // Domain or URL pattern
  reason      String                              // Why it's blocked
  threatType  String   @default("malware")        // malware, phishing, spam, scam, suspicious
  severity    String   @default("high")           // low, medium, high, critical
  source      String   @default("system")         // system, user, auto_detected
  isActive    Boolean  @default(true)
  hits        Int      @default(0)                // How many times this was triggered
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domain])
  @@index([isActive])
  @@map("url_blocklist")
}

// ============================================================
// Image Generation — Track AI-generated images
// ============================================================

model ImageGeneration {
  id              String   @id @default(cuid())
  userId          String
  prompt          String                          // The text prompt used
  model           String                          // Model used for generation
  provider        String   @default("openrouter") // Provider (openrouter, etc.)
  imageUrl        String?                         // URL or base64 of generated image
  status          String   @default("pending")    // pending, completed, failed
  costUsd         Float    @default(0)
  width           Int?
  height          Int?
  metadata        String   @default("{}")         // JSON metadata
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@map("image_generations")
}

// ============================================================
// Conversation — Chat conversations with agents
// ============================================================

model Conversation {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("chat")     // chat, automation, support
  userId    String
  agentId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, createdAt])
  @@map("conversations")
}

// ============================================================
// Message — Individual messages within conversations
// ============================================================

model Message {
  id             String   @id @default(cuid())
  role           String                       // user, assistant, system
  content        String
  model          String?
  provider       String?
  conversationId String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================================
// Knowledge — User knowledge base for long-term memory & RAG
// ============================================================

model Knowledge {
  id        String   @id @default(cuid())
  content   String
  category  String   @default("general")   // preference, project, document, workflow_context, agent_learning, episodic, semantic
  tags      String   @default("[]")
  source    String   @default("manual")     // conversation, document, manual, episodic, summarization
  relevance Float    @default(0.5)
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, createdAt])
  @@map("knowledge")
}

// ============================================================
// Document & DocumentChunk — RAG document storage
// ============================================================

model Document {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String   @default("unknown")
  fileSize  Int      @default(0)
  content   String   @default("")
  status    String   @default("processing")  // processing, ready, failed
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks    DocumentChunk[]

  @@index([userId, createdAt])
  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(cuid())
  content     String
  chunkIndex  Int      @default(0)
  pageNumber  Int?
  metadata    String   @default("{}")
  documentId  String
  userId      String
  createdAt   DateTime @default(now())

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

// ============================================================
// Agent Execution — Execution state persistence for agents
// ============================================================

model AgentExecution {
  id              String   @id @default(cuid())
  agentId         String
  userId          String
  task            String   @default("")
  steps           String   @default("[]")
  currentStep     Int      @default(0)
  totalSteps      Int      @default(0)
  status          String   @default("pending")    // pending, running, completed, failed, paused
  totalDuration   Int      @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  model           String?
  provider        String?
  result          String?
  error           String?
  state           String   @default("{}")         // JSON execution state
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@map("agent_executions")
}

// ============================================================
// Audit Log — Security audit trail for auth & admin actions
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String                          // login, logout, session_create, session_revoke, password_change, role_change, admin_action, etc.
  resource    String   @default("")           // Target resource type (user, agent, session, etc.)
  resourceId  String   @default("")           // Target resource ID
  details     String   @default("{}")         // JSON details of the action
  ipAddress   String?                         // Client IP at the time of action
  userAgent   String?                         // Client User-Agent
  severity    String   @default("info")       // info, warning, critical
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([severity, createdAt])
  @@map("audit_logs")
}

// ============================================================
// Video Generation — Track AI-generated videos
// ============================================================

model VideoGeneration {
  id              String   @id @default(cuid())
  userId          String
  prompt          String                          // The text prompt used
  mode            String   @default("t2v")        // t2v (text-to-video), i2v (image-to-video)
  model           String                          // cogvideo, videocrafter
  provider        String   @default("local")       // local, cloud, z-ai-sdk
  videoUrl        String?                         // URL or path to generated video
  status          String   @default("pending")    // pending, processing, completed, failed
  costUsd         Float    @default(0)
  durationSeconds Float    @default(0)            // Duration of the generated video
  width           Int?
  height          Int?
  fps             Int      @default(8)
  numFrames       Int?
  metadata        String   @default("{}")         // JSON metadata (seed, steps, guidance_scale, etc.)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@map("video_generations")
}

// ============================================================
// Voice Profile — User voice preferences
// ============================================================

model VoiceProfile {
  id          String   @id @default(cuid())
  userId      String
  language    String   @default("en-US")
  voiceModel  String   @default("alloy")
  speed       Float    @default(1.0)
  pitch       Float    @default(1.0)
  volume      Float    @default(1.0)
  provider    String   @default("openai")     // openai, elevenlabs, azure, etc.
  isActive    Boolean  @default(true)
  metadata    String   @default("{}")          // JSON: extra voice config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([provider])
  @@map("voice_profiles")
}

// ============================================================
// Voice Session — Active voice conversations (STT/TTS)
// ============================================================

model VoiceSession {
  id              String   @id @default(cuid())
  userId          String
  agentId         String?
  type            String   @default("stt")           // stt, tts, bidirectional
  status          String   @default("active")        // active, paused, ended, error
  language        String   @default("en-US")
  sttProvider     String   @default("openai")        // openai, deepgram, azure
  ttsProvider     String   @default("openai")        // openai, elevenlabs, azure
  transcription   String   @default("")              // Accumulated transcription text
  durationSeconds Int      @default(0)
  metadata        String   @default("{}")            // JSON: session config & stats
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("voice_sessions")
}

// ============================================================
// Voice Memory — Voice-based memories (audio embeddings, transcriptions)
// ============================================================

model VoiceMemory {
  id            String   @id @default(cuid())
  userId        String
  voiceSessionId String?
  category      String   @default("general")       // general, command, preference, context
  content       String                              // Transcribed text content
  embedding     String?                             // JSON: audio embedding vector
  audioUrl      String?                             // URL to stored audio clip
  durationMs    Int      @default(0)               // Duration of the audio clip in ms
  language      String   @default("en-US")
  confidence    Float    @default(0.0)             // STT confidence score 0-1
  tags          String   @default("[]")            // JSON array of tags
  metadata      String   @default("{}")            // JSON: extra metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, createdAt])
  @@map("voice_memories")
}

// ============================================================
// Voice Call — AI-powered phone calls
// ============================================================

model VoiceCall {
  id                String   @id @default(cuid())
  userId            String
  agentId           String?
  provider          String   @default("twilio")        // twilio, whatsapp
  fromNumber        String
  toNumber          String
  status            String   @default("ringing")       // ringing, connected, ended, failed
  language          String   @default("en-US")
  maxDurationMinutes Int     @default(30)
  recordingEnabled  Boolean  @default(false)
  recordingUrl      String?
  transcript        String   @default("[]")            // JSON: [{ role, content, timestamp }]
  durationSeconds   Int      @default(0)
  callSid           String?                             // Provider call SID
  metadata          String   @default("{}")            // JSON: extra call data
  startedAt         DateTime @default(now())
  endedAt           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([callSid])
  @@map("voice_calls")
}

// ============================================================
// Scheduled Task — Cron-based agent tasks
// ============================================================

model ScheduledTask {
  id          String    @id @default(cuid())
  userId      String
  agentId     String?
  name        String
  description String    @default("")
  schedule    String                                // Cron expression (e.g. "0 9 * * 1-5")
  timezone    String    @default("UTC")
  status      String    @default("active")         // active, paused, disabled, error
  lastRun     DateTime?
  nextRun     DateTime?
  runCount    Int       @default(0)
  failureCount Int      @default(0)
  payload     String    @default("{}")             // JSON: task input payload
  result      String?                               // JSON: last run result
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, nextRun])
  @@index([userId, createdAt])
  @@map("scheduled_tasks")
}

// ============================================================
// Agent Automation — Automation rules for agents
// ============================================================

model AgentAutomation {
  id          String   @id @default(cuid())
  userId      String
  agentId     String?
  name        String
  description String   @default("")
  trigger     String                             // event, schedule, webhook, condition
  conditions  String   @default("[]")            // JSON array of condition objects
  actions     String   @default("[]")            // JSON array of action objects
  isActive    Boolean  @default(true)
  runCount    Int      @default(0)
  lastTriggeredAt DateTime?
  metadata    String   @default("{}")            // JSON: extra config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, trigger])
  @@index([userId, createdAt])
  @@map("agent_automations")
}

// ============================================================
// Workspace — Team workspaces
// ============================================================

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  icon        String?
  settings    String   @default("{}")             // JSON: workspace-level settings
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  sharedAgents SharedAgent[]
  activities  WorkspaceActivity[]

  @@index([slug])
  @@map("workspaces")
}

// ============================================================
// Workspace Member — Workspace membership
// ============================================================

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member")         // owner, admin, member, viewer
  invitedBy   String?                              // User ID who sent the invite
  status      String   @default("active")         // active, invited, suspended
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// ============================================================
// Shared Agent — Agents shared within workspaces
// ============================================================

model SharedAgent {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String                              // Reference to Agent.id
  sharedBy    String                              // User ID who shared the agent
  permissions String   @default("[]")             // JSON: array of permission strings
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, agentId])
  @@index([workspaceId])
  @@index([agentId])
  @@map("shared_agents")
}

// ============================================================
// Marketplace Listing — Agent/workflow listings for sale/sharing
// ============================================================

model MarketplaceListing {
  id          String   @id @default(cuid())
  userId      String
  type        String                             // agent, workflow, template, plugin
  name        String
  slug        String   @unique
  description String
  category    String   @default("general")        // general, productivity, development, marketing, etc.
  tags        String   @default("[]")             // JSON array of tag strings
  price       Float    @default(0)                // 0 = free
  currency    String   @default("usd")
  config      String   @default("{}")             // JSON: agent/workflow configuration
  previewUrl  String?                             // Screenshot/demo URL
  downloads   Int      @default(0)
  rating      Float    @default(0)                // Average rating 0-5
  reviewCount Int      @default(0)
  status      String   @default("draft")          // draft, published, archived, suspended
  metadata    String   @default("{}")             // JSON: version, changelog, etc.
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews     MarketplaceReview[]
  purchases   MarketplacePurchase[]

  @@index([userId, status])
  @@index([type, status])
  @@index([category, status])
  @@index([slug])
  @@map("marketplace_listings")
}

// ============================================================
// Marketplace Review — Reviews for marketplace items
// ============================================================

model MarketplaceReview {
  id         String   @id @default(cuid())
  listingId  String
  userId     String
  rating     Int                                  // 1-5
  title      String   @default("")
  content    String   @default("")
  status     String   @default("published")      // published, hidden, flagged
  metadata   String   @default("{}")             // JSON: extra review data
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  listing    MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([listingId, createdAt])
  @@index([userId, createdAt])
  @@map("marketplace_reviews")
}

// ============================================================
// Marketplace Purchase — Purchase records
// ============================================================

model MarketplacePurchase {
  id           String   @id @default(cuid())
  listingId    String
  userId       String
  amount       Float    @default(0)
  currency     String   @default("usd")
  status       String   @default("completed")     // completed, refunded, disputed
  metadata     String   @default("{}")            // JSON: receipt, license info
  purchasedAt  DateTime @default(now())
  refundedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listing      MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([userId, createdAt])
  @@index([listingId, createdAt])
  @@map("marketplace_purchases")
}

// ============================================================
// Browser Automation — Browser automation sessions
// ============================================================

model BrowserAutomation {
  id           String   @id @default(cuid())
  userId       String
  agentId      String?
  url          String                              // Starting URL
  title        String?
  actions      String   @default("[]")            // JSON array of automation actions
  status       String   @default("idle")          // idle, running, paused, completed, error
  screenshots  String   @default("[]")            // JSON array of screenshot URLs/data
  result       String?                             // JSON: final result or output
  error        String?
  stepCount    Int      @default(0)
  currentStep  Int      @default(0)
  metadata     String   @default("{}")            // JSON: browser config, viewport, etc.
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("browser_automations")
}

// ============================================================
// Avatar Config — Avatar configurations
// ============================================================

model AvatarConfig {
  id          String   @id @default(cuid())
  userId      String
  name        String
  model       String   @default("default")        // Avatar model identifier
  style       String   @default("realistic")      // realistic, cartoon, anime, abstract
  voiceId     String?                              // Associated voice model ID
  expressions String   @default("[]")             // JSON: available expression configurations
  animations  String   @default("[]")             // JSON: available animation configurations
  customData  String   @default("{}")             // JSON: custom avatar properties
  thumbnailUrl String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, createdAt])
  @@map("avatar_configs")
}

// ============================================================
// Avatar Session — Active avatar sessions (lip-sync, speech)
// ============================================================

model AvatarSession {
  id            String   @id @default(cuid())
  userId        String
  avatarConfigId String?
  agentId       String?
  status        String   @default("active")        // active, speaking, idle, ended, error
  lipSyncData   String   @default("{}")            // JSON: lip-sync animation data
  speechText    String   @default("")              // Current speech text being rendered
  audioUrl      String?                             // URL to current audio stream
  videoUrl      String?                             // URL to video stream
  durationMs    Int      @default(0)               // Session duration in milliseconds
  metadata      String   @default("{}")            // JSON: session config & stats
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("avatar_sessions")
}

// ============================================================
// Multimodal Session — Real-time sessions (webcam, screen share, vision, audio)
// ============================================================

model MultimodalSession {
  id            String   @id @default(cuid())
  userId        String
  agentId       String?
  type          String   @default("vision")        // vision, webcam, screen_share, audio, multimodal
  status        String   @default("active")        // active, paused, ended, error
  inputModes    String   @default("[]")            // JSON: enabled input modes ["video", "audio", "screen"]
  outputModes   String   @default("[]")            // JSON: enabled output modes ["text", "audio", "video"]
  streamUrl     String?                             // URL to media stream
  recordings    String   @default("[]")            // JSON: array of recording URLs
  transcript    String   @default("")              // Session transcript text
  durationMs    Int      @default(0)               // Session duration in milliseconds
  frameCount    Int      @default(0)               // Number of processed frames
  metadata      String   @default("{}")            // JSON: resolution, fps, codec, etc.
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, createdAt])
  @@map("multimodal_sessions")
}

// ============================================================
// Memory Node — User personal knowledge graph nodes
// ============================================================

model MemoryNode {
  id          String   @id @default(cuid())
  userId      String
  type        String   @default("general")        // preference, project, habit, style, contact, topic, general
  label       String                               // Short label for the node
  content     String                               // Full content/data of this memory node
  metadata    String   @default("{}")             // JSON: extra node data (importance, context, etc.)
  weight      Float    @default(1.0)              // Weight/importance of this node
  accessCount Int      @default(0)                // How often this node is accessed
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  edgesFrom   MemoryEdge[] @relation("SourceNodes")
  edgesTo     MemoryEdge[] @relation("TargetNodes")

  @@index([userId, type])
  @@index([userId, createdAt])
  @@index([userId, isActive])
  @@map("memory_nodes")
}

// ============================================================
// Memory Edge — Relationships between memory nodes
// ============================================================

model MemoryEdge {
  id           String   @id @default(cuid())
  userId       String
  sourceNodeId String
  targetNodeId String
  relation     String                              // e.g., "prefers_for", "related_to", "part_of", "leads_to"
  weight       Float    @default(1.0)             // Edge weight/strength
  metadata     String   @default("{}")            // JSON: extra edge data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceNode   MemoryNode @relation("SourceNodes", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode   MemoryNode @relation("TargetNodes", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, relation])
  @@index([userId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("memory_edges")
}

// ============================================================
// Workspace Activity — Track workspace changes and events
// ============================================================

model WorkspaceActivity {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  action      String                              // e.g., "member_joined", "agent_shared", "role_updated", "comment_added"
  details     String   @default("{}")             // JSON: activity-specific details
  targetType  String?                             // e.g., "agent", "member", "workspace"
  targetId    String?                             // ID of the target entity
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId, isRead])
  @@index([workspaceId, action])
  @@map("workspace_activities")
}

// ============================================================
// User Personalization — AI personalization settings
// ============================================================

model UserPersonalization {
  id                    String   @id @default(cuid())
  userId                String   @unique
  communicationStyle    String   @default("balanced")    // concise, balanced, detailed, formal, casual
  technicalLevel        String   @default("intermediate") // beginner, intermediate, advanced, expert
  preferredFormat       String   @default("mixed")        // text, structured, mixed, code_first
  responseLength        String   @default("medium")       // brief, medium, comprehensive
  tonePreferences       String   @default("{}")           // JSON: tone settings (friendly, professional, etc.)
  topicInterests        String   @default("[]")           // JSON: array of interest topics
  languagePreference    String   @default("en")           // Preferred language code
  customInstructions    String   @default("")             // Custom system prompt additions
  interactionPatterns   String   @default("{}")           // JSON: learned interaction patterns
  feedbackHistory       String   @default("[]")           // JSON: past feedback for adaptation
  adaptationScore       Float    @default(0.0)           // How well the AI has adapted (0-1)
  totalInteractions     Int      @default(0)             // Total interactions tracked
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_personalizations")
}

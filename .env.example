# =============================================
# Genova SaaS — Environment Variables Template v2
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real API keys!
# =============================================

# ─── Database — PostgreSQL ────────────────────────────────────────────────────
DATABASE_URL=postgresql://genova:genova_secret@localhost:5432/genova

# ─── Redis — BullMQ Job Queue + Cache + Rate Limiting ─────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI Providers ─────────────────────────────────────────────────────────────
# DO NOT store these directly in .env for production.
# Use the Vault system (SecretVault) to manage encrypted API keys.
# These are here for development only.
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=

# ─── Vault / Secret Manager ──────────────────────────────────────────────────
# 64 hex chars (32 bytes) for AES-256-GCM encryption of API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_MASTER_KEY=

# ─── Auth Security ────────────────────────────────────────────────────────────
# PBKDF2 salt for password hashing (64 hex chars)
AUTH_SALT=
JWT_SECRET=
SESSION_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── WhatsApp Cloud API ──────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── GPU Server Endpoints (Tier 3 — Separate Server) ────────────────────────
# These point to the GPU server, NOT localhost
# Change these to your GPU server's IP/hostname
COMFYUI_API_URL=http://gpu-server:8188
SPEECHBRAIN_API_URL=http://gpu-server:8187
VIDEO_API_URL=http://gpu-server:8189

# ─── API IA / Orchestration (Tier 2) ─────────────────────────────────────────
RUFLO_MCP_URL=http://localhost:8190
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=
N8N_API_URL=http://localhost:5678
N8N_API_KEY=
BAILEYS_API_URL=http://localhost:8186

# ─── Qdrant Vector Database ──────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
VECTOR_STORE_TYPE=qdrant

# ─── Monitoring ───────────────────────────────────────────────────────────────
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=genova-backend
OTEL_TRACING_ENABLED=false

# Alert Webhook (Slack/Discord/etc.)
ALERT_WEBHOOK_URL=

# ─── AI Security Limits ──────────────────────────────────────────────────────
MAX_IMAGES_PER_HOUR=10
MAX_VIDEOS_PER_HOUR=5
MAX_AI_CHAT_PER_MINUTE=60
MAX_AI_CODE_PER_MINUTE=30
MAX_FILE_UPLOAD_SIZE_MB=50

# ─── App Settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app

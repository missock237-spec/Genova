# ============================================================
# Genova AgentOS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# For Vercel/production, use the Environment Variables dashboard.
# ============================================================

# ── DATABASE ──────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=file:./dev.db
#
# PostgreSQL (production):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
#   Examples:
#     Vercel Postgres:  postgres://default:xxxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require
#     Supabase:         postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#     Neon:             postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── AUTHENTICATION ────────────────────────────────────────────
# Required: Random secret for session tokens (min 32 chars)
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-characters

# Required: Global salt for legacy password hash verification
# Generate with: openssl rand -hex 32
AUTH_SALT=change-me-to-a-secure-random-salt-at-least-32-characters

# ── AI PROVIDERS ──────────────────────────────────────────────
# At least one AI provider is recommended for best performance.
# If none are set, the z-ai-web-dev-sdk is used as universal fallback.
#
# AI Router fallback chain: Groq (P1) → OpenRouter (P2) → z-ai-sdk
# Image generation fallback: OpenRouter → z-ai-sdk
# STT fallback: Groq → OpenAI → z-ai-sdk
# TTS fallback: OpenAI → z-ai-sdk

# Groq (https://console.groq.com) — Free tier available
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai) — Free models available
OPENROUTER_API_KEY=

# OpenAI (https://platform.openai.com) — For TTS, STT, Embeddings
OPENAI_API_KEY=

# ── APP URL ───────────────────────────────────────────────────
# Your production URL (used for CORS, OpenRouter referrer, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (optional)
CORS_ALLOWED_ORIGINS=

# ── EMAIL (Resend) ────────────────────────────────────────────
# For password reset and email verification flows
RESEND_API_KEY=
# Optional: Sender email address (default: Genova AgentOS <onboarding@resend.dev>)
EMAIL_FROM=

# ── WHATSAPP BUSINESS API ─────────────────────────────────────
# Optional: WhatsApp Cloud API integration (v21.0)
# Get credentials from: https://business.facebook.com
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── VOICE CALLS (Twilio) ─────────────────────────────────────
# Optional: Twilio integration for AI-powered phone calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── VIDEO GENERATION ──────────────────────────────────────────
# Optional: Local or remote video generation API endpoint
VIDEO_API_URL=http://localhost:8189
# Optional: Replicate API for cloud video generation (CogVideoX)
REPLICATE_API_TOKEN=

# ── IMAGE GENERATION ──────────────────────────────────────────
# OpenRouter API key also used for image generation (see above)
# If not set, z-ai-web-dev-sdk is used as fallback
# Available free models: flux-1-schnell-free, stable-diffusion-xl-free

# ── EMBEDDINGS ────────────────────────────────────────────────
# OpenAI API key used for text-embedding-3-small (see above)
# If not set, deterministic TF-IDF embeddings are used as fallback
EMBEDDING_MODEL=text-embedding-3-small

# ── VECTOR STORE (Optional) ──────────────────────────────────
# Default: sqlite (built-in, no external service needed)
# Alternative: qdrant (for production scale >10k vectors)
VECTOR_STORE_TYPE=sqlite
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── SANDBOX / CODE EXECUTION (Optional) ──────────────────────
# Default: subprocess (built-in, runs code in local subprocess)
# Alternative: e2b (cloud sandbox, requires E2B_API_KEY)
E2B_API_KEY=
SANDBOX_TYPE=subprocess

# ── N8N WORKFLOW AUTOMATION (Optional) ───────────────────────
# External n8n instance for advanced workflow automation
N8N_API_URL=
N8N_API_KEY=

# ── POCKETBASE (Optional) ────────────────────────────────────
# External PocketBase instance for agent learning data
POCKETBASE_URL=

# ── LOGGING ──────────────────────────────────────────────────
# Override application log level: debug, info, warn, error
# Default: debug in development, warn in production
LOG_LEVEL=

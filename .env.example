# =============================================
# Genova SaaS — Environment Variables Template
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real API keys!
# =============================================

# Database — PostgreSQL via bundled pg-service or Docker
DATABASE_URL=postgresql://genova:genova_secret@localhost:5432/genova

# AI Providers (Required for AI features)
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Email (Required for email features)
RESEND_API_KEY=your_resend_api_key_here

# WhatsApp Cloud API (Optional — used as fallback for Baileys)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Integration Servers — Local Microservices
SPEECHBRAIN_API_URL=http://localhost:8187
BAILEYS_API_URL=http://localhost:8186
COMFYUI_API_URL=http://localhost:8188
POCKETBASE_URL=http://localhost:8090
VIDEO_API_URL=http://localhost:8189
N8N_API_URL=http://localhost:5678
N8N_API_KEY=

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
VECTOR_STORE_TYPE=qdrant

# Ruflo MCP Server
RUFLO_MCP_URL=http://localhost:8190

# PocketBase Admin (Optional)
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

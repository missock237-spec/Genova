# ============================================================
# Genova AgentOS — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values.
# Vercel will use its own Environment Variables dashboard.
# ============================================================

# ── DATABASE ──────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Examples:
#   Vercel Postgres:  postgres://default:xxxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require
#   Supabase:         postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#   Neon:             postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── AUTHENTICATION ────────────────────────────────────────────
# Required: Random secret for password hashing (min 32 chars)
AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-characters

# ── AI PROVIDERS ──────────────────────────────────────────────
# At least one AI provider is required for agent functionality.
# If none are set, the z-ai-web-dev-sdk is used as fallback.

# Groq (https://console.groq.com)
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=

# ── APP URL ───────────────────────────────────────────────────
# Your production URL (used for CORS, OpenRouter referrer, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (optional)
CORS_ALLOWED_ORIGINS=

# ── EMAIL (Resend) ────────────────────────────────────────────
# For password reset and email verification flows
RESEND_API_KEY=

# ── WHATSAPP BUSINESS API ─────────────────────────────────────
# Optional: WhatsApp Cloud API integration
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── VIDEO GENERATION ──────────────────────────────────────────
# Optional: Local or remote video generation API endpoint
VIDEO_API_URL=http://localhost:8189

# Optional: Replicate API for cloud video generation
REPLICATE_API_TOKEN=

# ── IMAGE GENERATION ──────────────────────────────────────────
# OpenRouter API key also used for image generation (see above)
# If not set, z-ai-web-dev-sdk is used as fallback

# ── N8N WORKFLOW AUTOMATION (Optional) ────────────────────────
N8N_API_URL=
N8N_API_KEY=

# ── POCKETBASE (Optional — for agent learning data) ──────────
POCKETBASE_URL=

# Database — SQLite (development)
DATABASE_URL=file:./db/custom.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://genova:genova_password@localhost:5432/genova?schema=public

# ─── Security ───────────────────────────────────────────────────────────────
# REQUIRED: Must be set before starting the server.
# Generate with: openssl rand -hex 32
ENCRYPTION_SALT=7f8a9b2c3d4e5f60718293a4b5c6d7e8f90123456789abcdef0123456789abcd

# ─── Email Configuration (for password recovery) ────────────────────────────
# Option 1: Resend API (recommended — free tier: 100 emails/day)
# Sign up at https://resend.com and get your API key
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Option 2: SMTP (Gmail, SendGrid, Mailgun, etc.)
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=your-email@gmail.com

# If no email config is set, emails are logged to the console (dev mode)

# App URL (used for CORS and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

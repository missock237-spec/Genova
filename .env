DATABASE_URL=file:/home/z/my-project/db/custom.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://genova:genova_password@localhost:5432/genova

# ─── Security ───────────────────────────────────────────────────────────────
# REQUIRED: Must be set before starting the server.
# Generate with: openssl rand -hex 32
ENCRYPTION_SALT=7f8a9b2c3d4e5f60718293a4b5c6d7e8f90123456789abcdef0123456789abcd

# SMTP Configuration (for password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@genova.app

# App URL (used for CORS and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
